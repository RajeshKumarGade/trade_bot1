# --- Required ---
KITE_API_KEY=your_api_key
KITE_API_SECRET=your_api_secret

# --- Optional: provide this to skip Selenium token generation ---
# KITE_ACCESS_TOKEN=existing_access_token

# --- Required only if you want auto token generation in Railway ---
# KITE_USER_ID=your_user_id
# KITE_PASSWORD=your_password
# KITE_TOTP_SECRET=your_totp_secret
# CHROME_BIN=/usr/bin/chromium
# CHROMEDRIVER_PATH=/usr/bin/chromedriver

# --- Runtime ---
MARKET_TIMEZONE=Asia/Kolkata
MARKET_START=09:30
MARKET_END=15:15
SIGNAL_INTERVAL_MINUTES=5
SIGNAL_CHECK_WINDOW_SECONDS=5
MAIN_LOOP_SLEEP_SECONDS=1

# --- Storage ---
# Set to Railway volume mount path for persistence.
DATA_DIR=/data
TRADE_LOG_FILE_NAME=trade_history.csv
